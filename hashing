import hashlib

def md5_hash_string(input_string: str) -> str:
    """Zwraca wartość skrótu MD5 podanego ciągu w formacie hex."""
    hasher_md5 = hashlib.md5()
    hasher_md5.update(input_string.encode('utf-8'))  # zamiana tekstu na bajty
    return hasher_md5.hexdigest()  # zwraca hex

if __name__ == "__main__":
    text = "marek123"  # tutaj możesz podać dowolny tekst
    hash_hex = md5_hash_string(text)
    print(f"Skrót MD5 '{text}': {hash_hex}")

