import hashlib

def sha1_hash_string(input_string: str) -> str:
    """
    Zwraca wartość skrótu SHA-1 podanego ciągu w formacie hex.
    """
    hasher_sha1 = hashlib.sha1()
    hasher_sha1.update(input_string.encode('utf-8'))  # zamiana tekstu na bajty
    return hasher_sha1.hexdigest()  # zwraca hash w formacie hex

if __name__ == "__main__":
    text = "witaj świecie"  # możesz zmienić na dowolny tekst
    hash_hex = sha1_hash_string(text)
    print(f"Skrót SHA-1 dla '{text}': {hash_hex}")
